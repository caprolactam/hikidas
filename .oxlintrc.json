{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "react",
    "oxc",
    "import",
    "jsdoc",
    "vitest"
  ],
  "rules": {
    "react/exhaustive-deps": [
      "error",
      {
        "additionalHooks": "useIsomorphicEffect"
      }
    ]
  }
}
