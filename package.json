    "@hikidas/vue": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@react-spring/web": "^10.0.3",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
