{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "embeddedLanguageFormatting": "auto",
  "endOfLine": "lf",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "printWidth": 80,
  "semi": false,
  "trailingComma": "all",
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      "internal",
      "parent",
      "sibling",
      "index",
      "unknown"
    ],
    "newlinesBetween": false
  },
  "overrides": [
    { "files": ["*.jsonc"], "options": { "trailingComma": "none" } }
  ]
}
